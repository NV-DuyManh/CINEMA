<Window x:Class="Cinema.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cinema"
        mc:Ignorable="d"
        Title="Group6 Cinema - Đăng nhập Hệ thống" 
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0F2027" Offset="0.0"/>
            <GradientStop Color="#203A43" Offset="0.5"/>
            <GradientStop Color="#2C5364" Offset="1.0"/>
        </LinearGradientBrush>
    </Window.Background>

    <Window.Resources>
        <ControlTemplate x:Key="InputTemplate" TargetType="Control">
            <Border x:Name="border" Background="#F8F9FA" BorderBrush="#BDC3C7" BorderThickness="1.5" CornerRadius="8">
                <ScrollViewer x:Name="PART_ContentHost" Margin="10,0" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter TargetName="border" Property="BorderBrush" Value="#1ABC9C"/>
                    <Setter TargetName="border" Property="Background" Value="White"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Template" Value="{StaticResource InputTemplate}"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Template" Value="{StaticResource InputTemplate}"/>
        </Style>

        <Style TargetType="Button" x:Key="BtnPrimary">
            <Setter Property="Background" Value="#1ABC9C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="ExtraBold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="3" Color="#1ABC9C" Opacity="0.4"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#16A085"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="20" ShadowDepth="5" Color="#1ABC9C" Opacity="0.6"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#117A65"/>
                                <Setter Property="Effect" Value="{x:Null}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,50,0,0">
            <TextBlock Text="🎬 ZONE6 CINEMA" 
                       FontSize="42" 
                       FontWeight="Black" 
                       Foreground="#1ABC9C" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,5"/>

            <TextBlock Text="HỆ THỐNG QUẢN LÝ NỘI BỘ" 
                       FontSize="16" 
                       FontWeight="SemiBold" 
                       Foreground="#BDC3C7" 
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Border x:Name="LoginForm"
                    Width="450" 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center" 
                    Background="White" 
                    CornerRadius="16" 
                    Padding="45,55">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" ShadowDepth="10" Color="Black" Opacity="0.3"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="ĐĂNG NHẬP" 
                               FontSize="28" 
                               FontWeight="Heavy" 
                               Foreground="#2C3E50" 
                               HorizontalAlignment="Center" 
                               Margin="0,0,0,5"/>
                    <TextBlock Text="Vui lòng nhập thông tin nhân viên để truy cập"
                               FontSize="14" 
                               Foreground="#7F8C8D" 
                               HorizontalAlignment="Center" 
                               Margin="0,0,0,35"/>

                    <TextBlock Text="Tài khoản" FontWeight="Bold" FontSize="14" Foreground="#34495E" Margin="0,0,0,8"/>
                    <TextBox x:Name="txtTaiKhoan" Margin="0,0,0,20" ToolTip="Nhập tài khoản của bạn"/>

                    <TextBlock Text="Mật khẩu" FontWeight="Bold" FontSize="14" Foreground="#34495E" Margin="0,0,0,8"/>
                    <PasswordBox x:Name="txtMatKhau" Margin="0,0,0,10" ToolTip="Nhập mật khẩu"/>

                    <TextBlock Text="Quên mật khẩu?" 
                               HorizontalAlignment="Right" 
                               TextDecorations="Underline" 
                               Foreground="#1ABC9C" 
                               Cursor="Hand"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,0,0,35"
                               MouseLeftButtonDown="txtQuenMatKhau_MouseDown"/>

                    <Button Content="ĐĂNG NHẬP" 
                            Click="BtnDangNhap_Click" 
                            Style="{StaticResource BtnPrimary}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>